---
// DemoVideo.astro
---
<section id="demo-video" class="content-section">
  <div class="section-container">
    <h2 class="section-heading reveal">Demo Video</h2>

    <div class="video-block reveal">
      <div class="video-container">
        <iframe
          src="https://drive.google.com/file/d/1wWTNAS4955ns9qfJYYPXwjy6jgHvF9V2/preview"
          allow="autoplay; fullscreen"
          loading="lazy"
          title="CAV Black Box Demo"
        ></iframe>
      </div>
      <p class="video-caption">
        Demonstration of adaptive storage efficiency under high-vibration environments.
      </p>
    </div>
  </div>
</section>

<style>
  .section-heading {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    color: var(--color-primary);
    margin-bottom: 2rem;
    position: relative;
    padding-bottom: 0.75rem;
  }

  .section-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 4px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .video-block {
    background: #fff;
    padding: 1.5rem;
    border-radius: var(--radius-md);
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .video-container {
    width: 100%;
    aspect-ratio: 16 / 9; 
    background: #000;
    border-radius: 8px;
    overflow: hidden;
  }

  .video-container iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-caption {
    font-size: 0.9rem;
    color: var(--color-text-light);
    text-align: center;
    margin-top: 1.2rem;
    font-style: italic;
  }

  @media (max-width: 480px) {
    .section-heading {
      font-size: 1.2rem;
      margin-bottom: 1.5rem;
    }
    .video-block {
      padding: 0.75rem;
    }
  }

  @media (min-width: 481px) and (max-width: 768px) {
    .section-heading {
      font-size: 1.4rem;
    }
    .video-block {
      padding: 1rem;
    }
  }
</style>