  padding: 1.1rem;

  border-radius: 12px;
  border: 1px solid #e4e8ef;

  background: linear-gradient(#fff, #fafbfc);

  transition: all 0.25s ease;
}

.highlight-item:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(0,0,0,0.06);
  border-color: #c05e3c;
}

/* ===== NUMBER ICON ===== */
.highlight-icon {
  width: 30px;
  height: 30px;

  border-radius: 50%;
  background: #223253;
  color: white;

  font-size: 0.8rem;
  font-weight: 600;

  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== CONTENT ===== */
.highlight-content h4 {
  margin: 0 0 0.3rem;
  font-size: 1rem;
  color: #223253;
}

.highlight-content p {
  margin: 0;
  font-size: 0.9rem;
  color: #555;
}

/* ===== BRIDGE ===== */
.bridge-text {
  margin-top: 2rem;
}

.bridge-text p {
  font-size: 1.05rem;
  line-height: 1.8;
  text-align: justify;
}

.bridge-text strong {
  color: #c05e3c;
}

/* ===== SECTION ===== */
#research-questions {
  padding-top: 3rem;
}

/* Heading */
.section-heading {
  font-size: 1.5rem;
  font-weight: 500;
  margin-bottom: 2rem;
  position: relative;
}

.section-heading::after {
  width: 60px;   /* longer underline */
  height: 3px;
}

/* ===== GRID ===== */
.research-questions-box {
  display: grid;
  grid-template-columns: repeat(2, minmax(320px, 520px));
  justify-content: center;
  gap: 1.6rem;
}

/* ===== CARD ===== */
.question-item {
  display: flex;
  gap: 1rem;
  padding: 1.3rem 1.4rem;

  border-radius: 12px;
  border: 1px solid #e3e7ef;

  background: linear-gradient(
    135deg,
    #ffffff,
    #fafbfc
  );

  transition: all 0.3s ease;
  position: relative;
}

/* Hover (premium feel) */
.question-item:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 28px rgba(0,0,0,0.08);
  border-color: #c05e3c;
}

/* subtle accent glow */
.question-item::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 12px;
  background: radial-gradient(circle, rgba(192,94,60,0.06), transparent 70%);
  opacity: 0;
  transition: 0.3s;
}

.question-item:hover::after {
  opacity: 1;
}

/* ===== BADGE ===== */
.question-badge {
  width: 36px;
  height: 36px;
  min-width: 36px;

  font-size: 0.95rem;
  font-weight: 600;

  background: linear-gradient(135deg, #223253, #2f4a85);
