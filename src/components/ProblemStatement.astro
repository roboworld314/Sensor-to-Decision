}

/* ===== EMPHASIS ===== */
.question-content strong {
  color: #c05e3c;
  font-weight: 600;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
  .research-questions-box {
    grid-template-columns: 1fr;
  }
}
</style>