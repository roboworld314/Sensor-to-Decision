---
// DemoVideo.astro — Section 5: Fixed Media Gallery
---
<section id="demo-video" class="content-section">
  <div class="section-container">
    <h2 class="section-heading reveal">Real World Experiment</h2>

    <div class="media-grid reveal">
      
      <div class="media-item card video-item">
        <div class="video-container">
          <iframe
            src="https://drive.google.com/file/d/1XJ6RTKSLHpggS11d33h5RUC6NltZzXkD/preview"
            allow="autoplay"
            allowfullscreen
            frameborder="0"
          ></iframe>
        </div>
      </div>

      <div class="media-item card">
        <img src="https://lh3.googleusercontent.com/d/1_TBdIG1UbyEB6tQ_wzuksS9Ima-5Tifo" alt="Vibration Analysis 1" />
      </div>

      <div class="media-item card">
        <img src="https://lh3.googleusercontent.com/d/1J_BjOpYJwN7ZVhTn1hiGHkBT1WQkqpal" alt="Vibration Analysis" />
        <p>Outdoor testbed</p>
      </div>
      

    </div>
  </div>
</section>

<style>
  .section-heading {
    font-family: var(--font-heading);
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    position: relative;
    padding-bottom: 0.75rem;
  }

  .section-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 48px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .media-grid {
    display: flex;
    gap: 1.2rem;
    align-items: stretch;
    width: 100%;
  }

  .media-item {
    flex: 1;
    border-radius: 16px;
    overflow: hidden;
    background: #111;
    display: flex;
    aspect-ratio: 16 / 9;
    min-height: 180px;
  }

  .media-item img,
  .video-container iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-container {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Mobile: max-width 480px */
  @media (max-width: 480px) {
    .section-heading {
      font-size: 1.2rem;
      margin-bottom: 1.25rem;
    }

    .media-grid {
      flex-direction: column;
      gap: 0.75rem;
    }

    .media-item {
      aspect-ratio: 16 / 9;
      min-height: 150px;
    }
  }

  /* Tablet: 481px to 768px */
  @media (min-width: 481px) and (max-width: 768px) {
    .section-heading {
      font-size: 1.4rem;
      margin-bottom: 1.5rem;
    }

    .media-grid {
      flex-direction: column;
      gap: 1rem;
    }

    .media-item {
      aspect-ratio: 16 / 9;
      min-height: 200px;
    }
  }

  /* Desktop: 769px and up */
  @media (min-width: 769px) {
    .section-heading {
      font-size: 1.6rem;
    }

    .media-grid {
      gap: 1.2rem;
      flex-direction: row;
    }

    .media-item {
      aspect-ratio: 1;
    }

    .media-item:first-child {
      flex: 2;
    }
  }
</style>