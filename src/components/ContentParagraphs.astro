---
// ContentParagraphs.astro — Section: Contributions

const paragraphs = [

  "We target Connected and Autonomous Vehicles (CAVs), a high-pressure setting with massive sensor data, strict real-time constraints, and safety-critical decisions. Methods that succeed here naturally extend to other robotic systems.",

  "Our work is built around three key contributions:",

  "<strong>Adaptive sensory filtering.</strong> Vibration- and context-aware policy dynamically removes redundant data while preserving critical information. It leverages lightweight semantic cues and reinforcement learning to stay efficient and responsive in real time.",

  "<strong>Failure-aligned data curation.</strong> Instead of logging everything, the system captures compact, high-value data when perception quality drops-focusing on what truly matters for improving models.",

  "<strong>Strong real-world performance.</strong> Across benchmarks and real vehicles, SenseGuard delivers up to +20% accuracy, 75% lower trajectory error, significantly reduced latency, and 32% less storage."

];
---

<section id="content-paragraphs" class="content-section">
  <div class="section-container">
    <h2 class="section-heading reveal">Contributions</h2>

    <div class="prose reveal">
      {paragraphs.map((text) => (
        <p set:html={text}></p>
      ))}
    </div>
  </div>
</section>

<style>
  .section-heading {
    font-family: var(--font-heading);
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    position: relative;
    padding-bottom: 0.75rem;
  }

  .section-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 48px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .prose {
    max-width: 100%;
  }

  .prose p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 1.25rem;
    text-align: justify;
  }

  .prose p:last-child {
    margin-bottom: 0;
  }

  .prose strong {
    font-weight: 600;
    color: var(--color-primary);
  }

  /* Mobile: max-width 480px */
  @media (max-width: 480px) {
    .section-heading {
      font-size: 1.2rem;
      margin-bottom: 1.25rem;
    }

    .prose p {
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 1rem;
      text-align: left;
    }
  }

  /* Tablet: 481px to 768px */
  @media (min-width: 481px) and (max-width: 768px) {
    .section-heading {
      font-size: 1.4rem;
      margin-bottom: 1.5rem;
    }

    .prose p {
      font-size: 1rem;
      line-height: 1.7;
      margin-bottom: 1.15rem;
      text-align: left;
    }
  }

  /* Desktop: 769px and up */
  @media (min-width: 769px) {
    .section-heading {
      font-size: 1.6rem;
    }

    .prose p {
      font-size: 1.05rem;
      text-align: justify;
    }
  }
</style>