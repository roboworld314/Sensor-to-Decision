---
// ImageShowcase.astro — Section 3: Image/Video comparison groups

const imageGroups = [
  {
    description: "The Cost of Stale Perception: Vibration-Induced Failure in the Wild.",
    images: [
      { 
        src: "https://drive.google.com/file/d/1R2sQOs8LKBlH2kDEpd74cFOKFQpBsW0X/preview", 
        alt: "Conventional storage video", 
        isVideo: true 
      }, 
      { 
        src: "https://drive.google.com/thumbnail?id=1RfFGE0oFWyu_Y5CMWwD_ZAvSUXCY-Ycw&sz=w1000", 
    alt: "Adaptive storage", 
    isVideo: false
      },
    ],
  },
  // {
  //   description: "",
  //   images: [
  //     { 
  //       src: "https://drive.google.com/file/d/1d0NzHbr9tLY3J6kul0ASwKZL9BZiMAeu/preview", 
  //       alt: "Conventional storage video", 
  //       isVideo: true 
  //     }, 
  //     { 
  //       src: "https://drive.google.com/thumbnail?id=16Yvv_30e39Ls8XdcL4X_U8xKTXmARlnF&sz=w1000", 
  //       alt: "Adaptive storage", 
  //       isVideo: false 
  //     },
  //   ],
  // },
];
---

<section id="image-showcase" class="content-section">
  <div class="section-container">
    <h2 class="section-heading reveal">Problem Statement</h2>

    <div class="image-groups">
      {imageGroups.map((group, index) => (
        <div class="image-group reveal" style={`transition-delay: ${index * 0.1}s`}>
          <p class="group-description">{group.description}</p>
          <div class="image-pair">
            {group.images.map((media) => (
              <div class="image-card card">
                {media.isVideo ? (
                  <iframe 
                    src={media.src} 
                    width="100%" 
                    height="260" 
                    allow="autoplay" 
                    style="border:none;"
                    title={media.alt}>
                  </iframe>
                ) : (
                  <img src={media.src} alt={media.alt} loading="lazy" />
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<style>
  .section-heading {
    font-family: var(--font-heading);
    color: var(--color-primary);
    margin-bottom: 2rem;
    position: relative;
    padding-bottom: 0.75rem;
  }

  .section-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 48px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .image-groups {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .image-group {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border-light);
  }

  .image-group:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .group-description {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    max-width: 100%;
  }

  .image-pair {
    display: flex;
    gap: 1.2rem;
    width: 100%;
  }

  .image-card {
    flex: 1;
    border-radius: 12px;
    overflow: hidden;
    background: #f5f5f5;
    position: relative;
    aspect-ratio: 16 / 9;
  }

  .image-card img, 
  .image-card iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .image-card:hover img {
    transform: scale(1.03);
  }

  .reveal {
    opacity: 1 !important;
    transform: none !important;
  }

  /* Mobile: max-width 480px */
  @media (max-width: 480px) {
    .section-heading {
      font-size: 1.2rem;
      margin-bottom: 1.5rem;
    }

    .image-pair {
      flex-direction: column;
      gap: 1rem;
    }

    .group-description {
      font-size: 0.95rem;
      margin-bottom: 0.75rem;
    }
  }

  /* Tablet: 481px to 768px */
  @media (min-width: 481px) and (max-width: 768px) {
    .section-heading {
      font-size: 1.4rem;
      margin-bottom: 1.75rem;
    }

    .image-pair {
      flex-direction: column;
      gap: 1.2rem;
    }

    .group-description {
      font-size: 1rem;
    }
  }

  /* Desktop: 769px and up */
  @media (min-width: 769px) {
    .section-heading {
      font-size: 1.6rem;
    }

    .image-pair {
      gap: 1.2rem;
    }
  }
</style>