---
// Hero.astro — Title section with paper name
---
<section id="hero" class="hero-section">
  <div class="hero-inner">
    <div class="hero-badge">IROS 2026</div>
    <div>---
// Footer.astro — Section 6: Appendix link and footer
---
<section id="appendix" class="content-section footer-section">
  <div class="section-container">
    <div class="appendix-card reveal">
      <div class="appendix-inner">
        <div class="appendix-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="16" y1="13" x2="8" y2="13" />
            <line x1="16" y1="17" x2="8" y2="17" />
            <polyline points="10 9 9 9 8 9" />
          </svg>
        </div>
        <div class="appendix-content">
          <h3>Paper &amp; Appendix</h3>
          <p>Read the full paper and supplementary materials for detailed methodology, additional experiments, and ablation studies.</p>
          <div class="appendix-links">
            <!-- TODO: Replace '#' with your actual paper/appendix links -->
            <a href="#" class="link-button" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              Paper (PDF)
            </a>
            <a href="#" class="link-button link-secondary" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              Code (GitHub)
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="site-footer">
  <p>&copy; 2026 CAV Black Box. This page hosts supplementary demo materials for anonymous review.</p>
</footer>

<style>
  .footer-section {
    padding-bottom: 1rem;
  }

  .appendix-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    box-shadow: var(--shadow-card);
    transition: box-shadow var(--transition-smooth);
  }

  .appendix-card:hover {
    box-shadow: var(--shadow-elevated);
  }

  .appendix-inner {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .appendix-icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    background: rgba(192, 94, 60, 0.08);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
  }

  .appendix-content h3 {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--color-primary);
    margin-bottom: 0.6rem;
  }

  .appendix-content p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .appendix-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .link-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.3rem;
    background: var(--color-primary);
    color: white;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 100px;
    text-decoration: none;
    transition: all var(--transition-smooth);
    border: 1px solid var(--color-primary);
  }

  .link-button:hover {
    background: var(--color-primary-light);
    border-color: var(--color-primary-light);
    color: white;
    transform: translateY(-1px);
  }

  .link-button.link-secondary {
    background: transparent;
    color: var(--color-primary);
    border: 1px solid var(--color-border);
  }

  .link-button.link-secondary:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .site-footer {
    text-align: center;
    padding: 2rem 1.5rem 2.5rem;
    border-top: 1px solid var(--color-border-light);
  }

  .site-footer p {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  @media (max-width: 600px) {
    .appendix-inner {
      flex-direction: column;
    }

    .appendix-card {
      padding: 1.5rem;
    }
  }
</style>
</div>
    <h1 class="hero-title">
      <span class="title-main">SenseGuard: Sensor-to-Decision Adaptation for Reliable Agentic AI Robots</span>
    </h1>
    <p class="hero-subtitle">Adaptive and Efficient Storage under Vibration</p>

    <!-- TODO: Uncomment and fill in author info after acceptance -->
    <!--
    <div class="hero-authors">
      <p>Author 1<sup>1</sup>, Author 2<sup>2</sup>, Author 3<sup>1</sup></p>
      <p class="affiliations"><sup>1</sup>University A &nbsp; <sup>2</sup>University B</p>
    </div>
    -->
  </div>
</section>

<style>
  .hero-section {
    padding: 5rem 1.5rem 3rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(192, 94, 60, 0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(192, 94, 60, 0.08);
    border: 1px solid rgba(192, 94, 60, 0.2);
    padding: 0.4rem 1.2rem;
    border-radius: 100px;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: 3.2rem;
    font-weight: 400;
    color: var(--color-primary);
    line-height: 1.15;
    margin-bottom: 0.8rem;
    letter-spacing: -0.02em;
  }

  .title-main {
    display: block;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: 1.35rem;
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.5;
    max-width: 600px;
    margin: 0 auto;
    letter-spacing: 0.01em;
  }

  .hero-authors {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-light);
  }

  .hero-authors p {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .hero-authors .affiliations {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-top: 0.3rem;
  }

  .hero-authors sup {
    font-size: 0.7em;
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 3rem 1rem 2rem;
    }

    .hero-title {
      font-size: 2.2rem;
    }

    .hero-subtitle {
      font-size: 1.1rem;
    }
  }
</style>
