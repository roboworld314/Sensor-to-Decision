<style>

/* ===== HERO BASE ===== */
.hero-section {
  padding: 2.5rem 2rem 1.8rem;
  background: linear-gradient(135deg, #f7f5f2, #ece9e3);
}

/* ===== GRID ===== */
.hero-inner {
  max-width: 1100px;
  margin: auto;

  display: grid;
  grid-template-columns: 2fr 1fr;
  align-items: center;
  gap: 1.8rem;
}

/* ===== LEFT ===== */
.hero-left {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ===== TITLE ===== */
.hero-title {
  font-size: 2.2rem;
  line-height: 1.2;

  background: linear-gradient(135deg, #1a2740, #2f4a85);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* ===== SUBTITLE ===== */
.hero-subtitle {
  margin-top: 0.6rem;
  font-size: 1.02rem;
  color: #5c667a;
}

/* ===== PAPER BOX ===== */
.paper-box {
  margin-top: 1.5rem;
  
  padding: 0.5rem 1.4rem;  
  width: 100%;
  max-width: 750px;   /* 🔥 controls how wide it goes */

  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.6rem;

  border-radius: 12px;
  background: rgba(255,255,255,0.75);
  backdrop-filter: blur(10px);

  border: 1px solid rgba(0,0,0,0.05);
  box-shadow: 0 6px 18px rgba(0,0,0,0.05);

  transition: 0.25s ease;
}

.paper-box:hover {
  transform: translateY(-2px);
}

/* ===== BUTTONS ===== */
.paper-links {
  display: flex;
  gap: 0.45rem;
  flex-wrap: wrap;
  justify-content: center;
}

.paper-btn {
  padding: 0.4rem 0.8rem;
  border-radius: 8px;
  font-size: 0.78rem;
  transition: all 0.25s ease;
}

.paper-btn-primary {
  background: linear-gradient(135deg, #1f2f54, #2f4a85);
  color: white;
}

.paper-btn-secondary {
  border: 1px solid #d6dbe4;
  color: #3a445a;
}

/* ===== RIGHT VEHICLE ===== */
.hero-right {
  display: flex;
  justify-content: center;
  align-items: center;
}

/* ===== VEHICLE SYSTEM ===== */
.vehicle-wrapper {
  position: relative;
  width: 220px;
  height: 120px;
  overflow: hidden;

  display: flex;
  align-items: flex-end;
  justify-content: center;
}

/* ROAD */
.road {
  position: absolute;
  bottom: 12px;
  width: 100%;
  height: 3px;

  background: repeating-linear-gradient(
    to right,
    #bbb,
    #bbb 20px,
    transparent 20px,
    transparent 40px
  );

  animation: roadMove 1.2s linear infinite;
}

/* CAR */
.vehicle {
  position: absolute;
  bottom: 18px;
  left: -120px;
  width: 150px;

  animation: drive 6s linear infinite;
}

/* ===== ANIMATIONS ===== */
@keyframes drive {
  from { left: -120px; }
  to { left: 240px; }
}

@keyframes roadMove {
  from { background-position: 0; }
  to { background-position: 40px; }
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
  .hero-inner {
    grid-template-columns: 1fr;
  }

  .hero-title {
    font-size: 1.8rem;
  }

  .vehicle-wrapper {
    width: 180px;
    height: 100px;
  }

  .vehicle {
    width: 120px;
  }
}

</style>