---
// Hero.astro — Final Refined (1/3 Car + Tight Spacing)
---

<section id="hero" class="hero-section">

  <div class="hero-inner">

    <!-- LEFT CONTENT (2/3) -->
    <div class="hero-left">
      <h1 class="hero-title">
        SenseGuard: Sensor-to-Decision Adaptation for Reliable Agentic AI Robots
      </h1>

      <p class="hero-subtitle">
        Real-Time Adaptive Perception Decision Making under Vibration and Resource Constraints
      </p>

      <!-- Paper Box -->
      <div class="paper-box">
        <div class="paper-left">
          <span class="paper-icon">📄</span>
          <span class="paper-title">Supplementary Materials</span>
        </div>

        <div class="paper-links">
          <a href="https://drive.google.com/file/d/1adc8mrF3CoUz2dJ_2IxYwd5p2cFx412H/view"
             target="_blank" class="paper-btn paper-btn-primary">Appendix</a>

          <a href="#" class="paper-btn paper-btn-secondary"
             onclick="alert('We will publish soon!'); return false;">Code</a>

          <a href="#" class="paper-btn paper-btn-secondary"
             onclick="alert('We will publish soon!'); return false;">Dataset</a>

          <a href="/video" class="paper-btn paper-btn-primary">Demo Video</a>
        </div>
      </div>
    </div>

    <!-- RIGHT VISUAL (1/3) -->
    <div class="hero-right">
      <div class="vehicle-wrapper">
        <img 
          src="https://cdn-icons-png.flaticon.com/512/744/744465.png" 
          alt="Autonomous Vehicle"
          class="vehicle"
        />
      </div>
    </div>

  </div>
</section>

<style>

/* ===== BASE (REDUCED SPACE) ===== */
.hero-section {
  padding: 2.5rem 2rem 1.8rem;   /* 🔥 reduced top & bottom */
  background: linear-gradient(135deg, #f7f5f2, #ece9e3);
}

/* ===== GRID (2/3 + 1/3) ===== */
.hero-inner {
  max-width: 1100px;
  margin: auto;

  display: grid;
  grid-template-columns: 2fr 1fr;   /* 🔥 key change */
  align-items: center;
  gap: 1.8rem;
}

/* ===== LEFT ===== */
.hero-left {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ===== TITLE ===== */
.hero-title {
  font-size: 2.6rem;
  line-height: 1.2;

  background: linear-gradient(135deg, #1a2740, #2f4a85);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* ===== SUBTITLE ===== */
.hero-subtitle {
  margin-top: 0.6rem;
  font-size: 1.02rem;
  color: #5c667a;
}

/* ===== VEHICLE ===== */
.hero-right {
  display: flex;
  justify-content: center;
  align-items: center;
}

.vehicle-wrapper {
  width: 200px;   /* 🔥 reduced size */
}

.vehicle {
  width: 100%;
  opacity: 0.9;

  animation: floatCar 4s ease-in-out infinite;
  transition: transform 0.3s ease;
}

.vehicle:hover {
  transform: scale(1.06);
}

@keyframes floatCar {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
  100% { transform: translateY(0px); }
}

/* ===== PAPER BOX ===== */
.paper-box {
  margin-top: 1.5rem;   /* 🔥 tighter */
  padding: 0.9rem;

  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;

  border-radius: 12px;
  background: rgba(255,255,255,0.75);
  backdrop-filter: blur(10px);

  border: 1px solid rgba(0,0,0,0.05);
  transition: 0.25s ease;
}

.paper-box:hover {
  transform: translateY(-2px);
}

/* ===== BUTTONS ===== */
.paper-links {
  display: flex;
  gap: 0.45rem;
  flex-wrap: wrap;
  justify-content: center;
}

.paper-btn {
  padding: 0.4rem 0.8rem;
  border-radius: 8px;
  font-size: 0.78rem;
  transition: all 0.25s ease;
}

.paper-btn-primary {
  background: linear-gradient(135deg, #1f2f54, #2f4a85);
  color: white;
}

.paper-btn-secondary {
  border: 1px solid #d6dbe4;
  color: #3a445a;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
  .hero-inner {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .hero-title {
    font-size: 2rem;
  }

  .vehicle-wrapper {
    width: 160px;
  }
}

</style>