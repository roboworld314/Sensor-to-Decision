  font-weight: 500;
}

.btn-secondary:hover {
  background: rgba(0,0,0,0.04);
}
.btn-3rd:hover {
  background: rgba(0,0,0,0.04);
}
.btn-primary:hover {
  background: rgba(0,0,0,0.04);
}
</style>
