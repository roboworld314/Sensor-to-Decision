---
// Hero.astro — Title section with paper name
---

<section id="hero" class="hero-section">

  </div>

    <h1 class="hero-title">
      SenseGuard: Sensor-to-Decision Adaptation for Reliable Agentic AI Robots
    </h1>

    <p class="hero-subtitle">
      Adaptive and Efficient Storage under Vibration
    </p>

  </div>

  <div class="hero-inner">

    <!-- Paper banner -->
    <div class="paper-box">

      <div class="paper-left">
        <span class="paper-icon">📄</span>
        <span class="paper-title">Supplementary Materials</span>
      </div>

      <div class="paper-links">
        <a href="/appendix.pdf" class="paper-btn">Appendix</a>
        <a href="https://github.com/yourrepo" class="paper-btn">Code</a>
        <a href="/dataset" class="paper-btn">Dataset</a>
        <a href="/video" class="paper-btn">Video</a>
      </div>

  
</section>


<style>

.hero-section {
  padding: 5rem 1.5rem 3rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(192,94,60,0.06) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 1100px;
  margin: 0 auto;
}


/* ---------------- */
/* Paper Banner */
/* ---------------- */

.paper-box{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:2rem;

  width:100%;
  max-width:900px;
  margin:0 auto 2rem auto;

  padding:1rem 1.5rem;

  background:#f4f4f4;
  border-radius:22px;
  border:1px solid rgba(0,0,0,0.08);
}

.paper-left{
  display:flex;
  align-items:center;
  gap:.5rem;
  font-weight:600;
  color:var(--color-primary);
}

.paper-icon{
  font-size:1.3rem;
}

.paper-links{
  display:flex;
  gap:.7rem;
  align-items:center;
}

/* Buttons */
.paper-btn{
  background:#223253;
  color:white;

  min-width:110px;      /* same width */
  text-align:center;

  padding:.55rem 1rem;
  border-radius:30px;

  font-size:.9rem;
  font-weight:500;
  text-decoration:none;

  transition:all .2s ease;
}

.paper-btn:hover{
  background:#1a2740;
}

/* ---------------- */
/* Title */
/* ---------------- */

.hero-title {
  font-family: var(--font-heading);
  font-size: 3.2rem;
  font-weight: 400;
  color: var(--color-primary);
  line-height: 1.15;
  margin-bottom: 0.8rem;
  letter-spacing: -0.02em;
}

.hero-subtitle {
  font-family: var(--font-body);
  font-size: 1.35rem;
  font-weight: 300;
  color: var(--color-text-muted);
  line-height: 1.5;
  max-width: 600px;
  margin: 0 auto;
}


/* ---------------- */
/* Mobile */
/* ---------------- */

@media (max-width:768px){

  .hero-section{
    padding:3rem 1rem 2rem;
  }

  .hero-title{
    font-size:2.2rem;
  }

  .hero-subtitle{
    font-size:1.1rem;
  }

  .paper-box{
    flex-direction:column;
  }

}

</style>