.paper-box{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:.8rem;

  width:100%;
  max-width:1000px;
  margin:0 auto 2rem auto;

  padding:.9rem 1.5rem;

  background:#f4f4f4;
  border-radius:20px;
  border:1px solid rgba(0,0,0,0.08);

  font-size:1rem;
}

.paper-left{
  display:flex;
  align-items:center;
  gap:.5rem;
  font-weight:600;
  color:var(--color-primary);
}

.paper-icon{
  font-size:1.2rem;
}

.paper-links{
  display:flex;
  align-items:center;
  gap:.7rem;
}

.paper-links a{
  text-decoration:none;
  color:#243453;
  font-weight:500;
}

.paper-links a:hover{
  text-decoration:underline;
}

.divider{
  color:#999;
}

.paper-content{
  flex:1;
}

.paper-content h3{
  font-size:1.4rem;
  margin-bottom:.25rem;
  color:var(--color-primary);
}

.paper-content p{
  font-size:.95rem;
  margin-bottom:.6rem;
  color:var(--color-text-muted);
}

.paper-buttons{
  display:flex;
  gap:.8rem;
}


.btn-primary {
  background: #223253;
  color: white;
  padding: .8rem 1.6rem;
  border-radius: 40px;
  text-decoration: none;
  font-weight: 500;
}

.btn-secondary {
  background: #223253;
  color: white;
  padding: .8rem 1.6rem;
