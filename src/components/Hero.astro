 .paper-box {
  display: flex;
  align-items: center;
  gap: 1.8rem;
  background: #f4f4f4;
  border-radius: 22px;
  padding: 2.2rem 2.5rem;
  margin-bottom: 2.5rem;
  border: 1px solid rgba(0,0,0,0.08);
}

.paper-icon {
  width: 64px;
  height: 64px;
  background: #f1eae6;
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.6rem;
}

.paper-content h3 {
  font-size: 1.8rem;
  margin-bottom: .5rem;
  color: var(--color-primary);
}

.paper-content p {
  color: var(--color-text-muted);
  margin-bottom: 1.3rem;
  max-width: 620px;
}

.paper-buttons {
  display: flex;
  gap: 1rem;
}

.btn-primary {
  background: #223253;
  color: white;
  padding: .8rem 1.6rem;
  border-radius: 40px;
  text-decoration: none;
  font-weight: 500;
}

.btn-secondary {
  border: 1px solid rgba(0,0,0,0.2);
  padding: .8rem 1.6rem;
  border-radius: 40px;
  text-decoration: none;
  color: var(--color-primary);
}

.btn-secondary:hover {
  background: rgba(0,0,0,0.04);
}
</style>
