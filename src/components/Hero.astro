---
// Hero.astro — Enhanced Version
---

<section id="hero" class="hero-section">
 
  
  <div class="hero-inner">

    <!-- Title -->
    <div class="hero-content">
      <h1 class="hero-title">
        SenseGuard: Sensor-to-Decision Adaptation for Reliable Agentic AI Robots
      </h1>

      <p class="hero-subtitle">
        Real-Time Adaptive Perception Decision Making under Vibration and Resource Constraints
      </p>
    </div>

    <!-- Paper Box -->
    <div class="paper-box">
      <div class="paper-left">
        <span class="paper-icon">📄</span>
        <span class="paper-title">Supplementary Materials</span>
      </div>

      <div class="paper-links">
        <a href="https://drive.google.com/file/d/1adc8mrF3CoUz2dJ_2IxYwd5p2cFx412H/view?usp=sharing"
           target="_blank" class="paper-btn paper-btn-primary">
          Appendix
        </a>

        <a href="#" class="paper-btn paper-btn-secondary"
           onclick="alert('We will publish soon!'); return false;">
          Code
        </a>

        <a href="#" class="paper-btn paper-btn-secondary"
           onclick="alert('We will publish soon!'); return false;">
          Dataset
        </a>

        <a href="/video" class="paper-btn paper-btn-primary">
          Demo Video
        </a>
      </div>
    </div>

  </div>
</section>

<style>
/* ===== BASE ===== */
.hero-section {
  padding: 4rem 2rem;
  text-align: center;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #f7f5f2 0%, #ece9e3 100%);
}

/* ===== BACKGROUND ===== */
.hero-background {
  position: absolute;
  inset: 0;
  z-index: 0;
}

/* Animated car */
.car-gif {
  position: absolute;
  bottom: 0;
  left: -20%;
  width: 500px;
  opacity: 0.15;
  animation: drive 18s linear infinite;
}

@keyframes drive {
  from { transform: translateX(0); }
  to { transform: translateX(140vw); }
}

/* Overlay */
.gradient-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(255,255,255,0.95),
    rgba(255,255,255,0.7),
    transparent
  );
}

/* ===== CONTENT ===== */
.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 1100px;
  margin: auto;
}

/* Badge */
.hero-badge {
  display: inline-block;
  margin-bottom: 1rem;
  padding: 0.3rem 0.9rem;
  border-radius: 999px;
  font-size: 0.75rem;
  background: rgba(34, 50, 83, 0.1);
  color: #223253;
}

/* Title */
.hero-title {
  font-size: 3rem;
  font-weight: 500;
  line-height: 1.2;
  background: linear-gradient(135deg, #1a2740, #2f4a85);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* Subtitle */
.hero-subtitle {
  margin-top: 0.6rem;
  font-size: 1.1rem;
  color: #5c667a;
}

/* ===== PAPER BOX ===== */
.paper-box {
  margin-top: 2.5rem;
  padding: 1.4rem;
  border-radius: 16px;

  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1rem;

  backdrop-filter: blur(12px);
  background: rgba(255,255,255,0.75);

  border: 1px solid rgba(255,255,255,0.4);
  box-shadow: 0 8px 30px rgba(0,0,0,0.05);

  transition: all 0.3s ease;
}

.paper-box:hover {
  transform: translateY(-4px);
}

/* Left */
.paper-left {
  font-weight: 600;
  color: #223253;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

/* Buttons */
.paper-links {
  display: flex;
  gap: 0.6rem;
  flex-wrap: wrap;
}

.paper-btn {
  padding: 0.5rem 1rem;
  border-radius: 10px;
  font-size: 0.85rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s ease;
}

/* Primary */
.paper-btn-primary {
  background: linear-gradient(135deg, #1f2f54, #2f4a85);
  color: white;
  box-shadow: 0 4px 15px rgba(47, 74, 133, 0.3);
}

.paper-btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(47, 74, 133, 0.5);
}

/* Secondary */
.paper-btn-secondary {
  border: 1px solid #ccd2dc;
  color: #223253;
}

.paper-btn-secondary:hover {
  background: #223253;
  color: white;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
  .hero-title {
    font-size: 2rem;
  }

  .car-gif {
    width: 300px;
  }

  .paper-box {
    flex-direction: column;
  }
}
</style>